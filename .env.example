# Image used by compose.yaml. Use a Daptin tag that includes OAuth provider support.
DAPTIN_IMAGE=daptin/daptin:v0.11.6

# Browser-facing Daptin URL.
DAPTIN_BASE_URL=http://localhost:6336
DAPTIN_BROWSER_URL=http://localhost:6336

# Server-to-server Daptin URLs. For local Node these can stay as localhost.
# Docker Compose overrides these to http://daptin:8080.
DAPTIN_API_URL=http://localhost:6336
DAPTIN_INTERNAL_URL=http://localhost:6336

DEMO_BASE_URL=http://localhost:7777
LISTEN_HOST=localhost

# Optional. If omitted, scripts/setup.js creates/signs in the demo admin user below.
DAPTIN_ADMIN_TOKEN=

DEMO_ADMIN_EMAIL=demo-admin@example.com
DEMO_ADMIN_PASSWORD=demo-admin-password

# Generated by npm run setup.
AUTHENTICATOR_NAME=
OAUTH_APP_REFERENCE_ID=
OAUTH_CONNECT_REFERENCE_ID=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
